generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ───

model User {
  id        String   @id @default(cuid())
  name      String?
  username  String   @unique
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  engrams  Engram[]
  apiKeys  ApiKey[]
}

model Engram {
  id              String     @id // "eng_" + nanoid
  sourceEngramId  String     // local-compatible Relic ID (e.g. "johnny")
  name            String
  description     String?
  visibility      Visibility @default(PRIVATE)
  tags            String[]   @default([])
  avatarUrl       String?
  ownerId         String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  owner        User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  personaFiles EngramPersonaFile[]
  memoryBlob   EngramMemoryBlob?

  @@unique([ownerId, sourceEngramId])
  @@index([ownerId])
  @@index([visibility])
}

/// Plaintext persona files: SOUL.md, IDENTITY.md, engram.json
model EngramPersonaFile {
  id        String          @id @default(cuid())
  engramId  String
  fileType  PersonaFileType
  filename  String          // "SOUL.md", "IDENTITY.md", "engram.json"
  content   String          @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  engram Engram @relation(fields: [engramId], references: [id], onDelete: Cascade)

  @@unique([engramId, fileType])
  @@index([engramId])
}

/// Client-side encrypted memory bundle (one per Engram).
/// Contains USER.md, MEMORY.md, and memory/*.md in an opaque encrypted blob.
model EngramMemoryBlob {
  id               String   @id @default(cuid())
  engramId         String   @unique
  version          Int      @default(1)
  ciphertext       Bytes
  cipherAlgorithm  String   // e.g. "AES-256-GCM"
  cipherNonce      Bytes
  wrappedBundleKey Bytes
  wrapAlgorithm    String   // e.g. "AES-256-GCM"
  kdfAlgorithm     String   // e.g. "scrypt"
  kdfSalt          Bytes
  kdfParamsJson    Json     // { N, r, p, dkLen }
  manifestJson     Json     // { payloadKind, bundleVersion, hasUserFile, ... }
  bundleHash       String   // "sha256:<hex>"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  engram Engram @relation(fields: [engramId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  hashedKey  String    @unique
  prefix     String // "mk_...xxxx" for identification
  userId     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum PersonaFileType {
  SOUL
  IDENTITY
  ENGRAM_JSON
}
