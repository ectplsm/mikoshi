generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ───

model User {
  id        String   @id @default(cuid())
  name      String?
  username  String   @unique
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  engrams  Engram[]
  apiKeys  ApiKey[]
}

model Engram {
  id          String     @id // "eng_" + nanoid
  name        String
  description String?
  visibility  Visibility @default(PRIVATE)
  tags        String[]   @default([])
  avatarUrl   String?
  ownerId     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files EngramFile[]

  @@index([ownerId])
  @@index([visibility])
}

model EngramFile {
  id        String   @id @default(cuid())
  engramId  String
  fileType  FileType
  filename  String // "SOUL.md", "memory/2026-03-21.md", etc.
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engram Engram @relation(fields: [engramId], references: [id], onDelete: Cascade)

  @@unique([engramId, filename])
  @@index([engramId])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  hashedKey  String    @unique
  prefix     String // "mk_...xxxx" for identification
  userId     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum FileType {
  SOUL
  IDENTITY
  AGENTS
  USER
  MEMORY
  HEARTBEAT
  MEMORY_ENTRY
}
